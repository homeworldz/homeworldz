{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "HomeWorldz development",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
